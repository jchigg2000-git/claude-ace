{
  "name": "claude-ace",
  "version": "0.1.1",
  "description": "Show a pretty terminal summary of your local Claude Code session logs — token totals, top models, event types — with a hydration animation.",
  "type": "module",
  "bin": {
    "claude-ace": "bin/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "test": "node --test 'test/**/*.test.js'",
    "prepublishOnly": "node ./bin/cli.js --help >/dev/null"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "usage",
    "logs",
    "stats"
  ],
  "author": "Justin Higgins",
  "license": "MIT",
  "homepage": "https://github.com/jchigg2000-git/claude-ace#readme",
  "bugs": {
    "url": "https://github.com/jchigg2000-git/claude-ace/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchigg2000-git/claude-ace.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
